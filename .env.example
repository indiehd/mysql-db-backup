# MySQL/MariaDB Database Connection Settings
#
# IMPORTANT: Choose the configuration that matches your setup below

# ============================================================================
# NETWORK MODE CONFIGURATION
# ============================================================================
# Choose your Docker networking mode:
#   - "host"   = Container shares host network (MySQL on localhost)
#   - "bridge" = Default Docker network (better isolation)
#   - Custom network name for multi-container setups
#
# Default: "host" (recommended for single-server MySQL on localhost)
DOCKER_NETWORK_MODE=host

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
# Configure based on your network mode:
#
# For DOCKER_NETWORK_MODE=host:
#   DB_HOST=localhost
#   Requires MariaDB user: CREATE USER 'backup'@'localhost' ...
#
# For DOCKER_NETWORK_MODE=bridge:
#   DB_HOST=172.17.0.1  (or host.docker.internal on some systems)
#   Requires MariaDB user: CREATE USER 'backup'@'%' ...
#                      or: CREATE USER 'backup'@'172.%' ...
#
# For custom Docker network:
#   DB_HOST=mysql_container_name
#   Requires MariaDB user: CREATE USER 'backup'@'%' ...

DB_HOST=localhost
DB_USERNAME=backup
DB_PASSWORD=your_secure_password_here

# ============================================================================
# BACKUP SETTINGS (Optional)
# ============================================================================
# Backup directory inside container (usually don't need to change this)
# BACKUP_DIR=/backups
